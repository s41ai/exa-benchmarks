OPENAI_API_KEY=your-openai-api-key
SUPERCARL_API_KEY=your-supercarl-api-key
SUPERCARL_BASE_URL=https://api.supercarl.ai

# Optional: run searches on behalf of an allocated team seat.
SUPERCARL_DELEGATE_USER_ID=

# Optional: include GET /api/v1/profiles/:id/text calls for richer grading context.
SUPERCARL_INCLUDE_PROFILE_TEXT=false
SUPERCARL_PROFILE_TEXT_MODE=full
SUPERCARL_PROFILE_TEXT_POSTS_LIMIT=5
